# Secret used to sign admin login JWTs. Change this to a long random string in production.
JWT_SECRET=replace-this-with-a-long-random-string

# Admin login credentials (used by /api/auth/login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Optional: lets the contact form email submissions straight to your Gmail.
# See README -> "Wiring up real email delivery" for how to generate an
# App Password. Leave blank to just save messages to data/messages.json.
GMAIL_USER=
GMAIL_APP_PASSWORD=
